  "item": [
    {
      "name": "0 - Santé",
      "item": [
        {
          "name": "GET /api/tasks - application disponible",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('activeTasks présent', function () { pm.expect(body).to.have.property('activeTasks'); });",
                  "pm.test('queueSize présent', function () { pm.expect(body).to.have.property('queueSize'); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tasks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "tasks"
              ]
            },
            "description": "Health-check minimal du backend avant de dérouler le scénario."
          }
        }
      ]
    },
    {
