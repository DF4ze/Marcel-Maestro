              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created', function () { pm.response.to.have.status(201); });",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('projectIdA', body.id);",
                  "pm.test('projectIdA mémorisé', function () { pm.expect(pm.collectionVariables.get('projectIdA')).to.be.a('string').and.not.empty; });",
                  "console.log('projectIdA =', body.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
