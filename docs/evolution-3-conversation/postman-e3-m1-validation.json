    {
      "name": "2 - Conversation A / premier échange LLM",
      "item": [
        {
          "name": "Créer conversation A",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created', function () { pm.response.to.have.status(201); });",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('conversationIdA', body.id);",
                  "pm.test('conversationIdA mémorisé', function () { pm.expect(pm.collectionVariables.get('conversationIdA')).to.be.a('string').and.not.empty; });",
                  "pm.test('status OPEN', function () { pm.expect(body.status).to.equal('OPEN'); });",
                  "console.log('conversationIdA =', body.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectIdA}}/conversations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "projects",
                "{{projectIdA}}",
                "conversations"
              ]
            }
          }
        },
        {
          "name": "POST /messages - premier message conversationnel",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('assistantReply1', body.content);",
                  "pm.test('role ASSISTANT', function () { pm.expect(body.role).to.equal('ASSISTANT'); });",
                  "pm.test('content non vide', function () { pm.expect(body.content).to.be.a('string').and.not.empty; });",
                  "console.log('assistantReply1 =', body.content);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Bonjour Marcel, présente-toi en une phrase.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectIdA}}/conversations/{{conversationIdA}}/messages",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "projects",
                "{{projectIdA}}",
                "conversations",
                "{{conversationIdA}}",
                "messages"
              ]
            }
          }
        },
        {
          "name": "GET /messages - vérifier USER + ASSISTANT",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('2 messages', function () { pm.expect(body.length).to.equal(2); });",
                  "pm.test('1er rôle USER', function () { pm.expect(body[0].role).to.equal('USER'); });",
                  "pm.test('2e rôle ASSISTANT', function () { pm.expect(body[1].role).to.equal('ASSISTANT'); });",
                  "pm.test('message utilisateur correct', function () { pm.expect(body[0].content).to.equal('Bonjour Marcel, présente-toi en une phrase.'); });",
                  "pm.test('réponse assistant présente', function () { pm.expect(body[1].content).to.be.a('string').and.not.empty; });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectIdA}}/conversations/{{conversationIdA}}/messages",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "projects",
                "{{projectIdA}}",
                "conversations",
                "{{conversationIdA}}",
                "messages"
              ]
            }
          }
        }
