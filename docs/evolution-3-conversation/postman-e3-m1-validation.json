        {
          "name": "GET /messages - vérifier 4 messages après deux échanges",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('4 messages', function () { pm.expect(body.length).to.equal(4); });",
                  "pm.test('séquence USER/ASSISTANT/USER/ASSISTANT', function () {",
                  "  pm.expect(body.map(m => m.role)).to.eql(['USER', 'ASSISTANT', 'USER', 'ASSISTANT']);",
                  "});",
                  "pm.test('2e message utilisateur correct', function () { pm.expect(body[2].content).to.equal('Quel était mon premier message ?'); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectIdA}}/conversations/{{conversationIdA}}/messages",
