        {
          "name": "Étape manuelle SQL - vérifier USER + ASSISTANT dans SPRING_AI_CHAT_MEMORY",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tasks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "tasks"
              ]
            },
            "description": "Action manuelle hors Postman. Ouvrir data/mm-memory.db puis exécuter :\n\nSELECT conversation_id, type, content\nFROM SPRING_AI_CHAT_MEMORY\nWHERE conversation_id IN ('{{conversationIdA}}', '{{conversationIdB}}')\nORDER BY conversation_id, timestamp;\n\nAttendus :\n- conversation A : 4 lignes = USER, ASSISTANT, USER, ASSISTANT\n- conversation B : 2 lignes = USER, ASSISTANT\n- aucune pollution croisée entre A et B"
          }
        }
      ]
    },
    {
      "name": "6 - Telegram (note)",
      "item": [
        {
          "name": "Étape informative - Telegram n'est pas le bon canal pour valider E3-M1",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tasks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "tasks"
              ]
            },
            "description": "E3-M1 valide le nouveau endpoint REST conversationnel. Le canal Telegram continue de passer par le flux tâches/orchestrateur, donc il n'est pas pertinent pour valider la réponse LLM directe de POST /projects/{projectId}/conversations/{conversationId}/messages. Tu peux l'utiliser uniquement pour vérifier qu'E3-M0 n'a pas été cassé (/switch, /reset, continuité de conversationId)."
          }
        }
      ]
    },
