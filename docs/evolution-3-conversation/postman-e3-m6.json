{
  "info": {
    "name": "Marcel Maestro - E3-M6",
    "_postman_id": "be9570b4-c39f-4ba8-9ef6-2d26c1f5f451",
    "description": "Plan de test E3-M6 : SSE + conversation_task + verification REST du flux Telegram.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "projectId", "value": "" },
    { "key": "conversationId", "value": "" }
  ],
  "item": [
    {
      "name": "1 - Setup",
      "item": [
        {
          "name": "Create project",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Test E3-M6\"\n}" },
            "url": "{{baseUrl}}/projects"
          }
        },
        {
          "name": "Create conversation",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects/{{projectId}}/conversations"
          }
        }
      ]
    },
    {
      "name": "2 - Fix Telegram via REST",
      "item": [
        {
          "name": "Batch assistant response",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"content\": \"Bonjour Marcel\"\n}" },
            "url": "{{baseUrl}}/projects/{{projectId}}/conversations/{{conversationId}}/messages"
          }
        }
      ]
    },
    {
      "name": "3 - SSE",
      "item": [
        {
          "name": "Stream assistant response",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "text/event-stream" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"content\": \"Bonjour Marcel\"\n}" },
            "url": "{{baseUrl}}/projects/{{projectId}}/conversations/{{conversationId}}/messages"
          }
        },
        {
          "name": "List persisted messages after stream",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects/{{projectId}}/conversations/{{conversationId}}/messages"
          }
        }
      ]
    },
    {
      "name": "4 - conversation_task",
      "item": [
        {
          "name": "Trigger submit_task",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"content\": \"Lance un build Maven du projet\"\n}" },
            "url": "{{baseUrl}}/projects/{{projectId}}/conversations/{{conversationId}}/messages"
          }
        },
        {
          "name": "List conversation tasks",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects/{{projectId}}/conversations/{{conversationId}}/tasks"
          }
        }
      ]
    },
    {
      "name": "5 - Cleanup",
      "item": [
        {
          "name": "Delete conversation",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/projects/{{projectId}}/conversations/{{conversationId}}"
          }
        },
        {
          "name": "Delete project",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/projects/{{projectId}}"
          }
        }
      ]
    }
  ]
}
